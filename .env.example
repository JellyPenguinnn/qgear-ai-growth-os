QGEAR_ENV=demo
QGEAR_SQLITE_PATH=data/sqlite/qgear.db
QGEAR_DUCKDB_PATH=data/duckdb/qgear.duckdb
QGEAR_CACHE_DIR=data/cache

# SEC requires a descriptive User-Agent with contact information.
SEC_USER_AGENT="qgear-ai-growth-os personal research app your-email@example.com"
SEC_MAX_REQUESTS_PER_SECOND=10

# Optional provider keys. Leave blank for mock/demo mode.
QGEAR_PRICE_PROVIDER=mock
QGEAR_AI_PROVIDER=none
QGEAR_AI_MODEL=
OPENAI_API_KEY=
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=
EIA_API_KEY=

# Frontend. Keep this localhost-only unless you intentionally accept sending local
# research, journal, and portfolio data to another API host.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
